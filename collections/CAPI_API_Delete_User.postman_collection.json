{
  "info": {
    "name": "CAPI API - Delete User",
    "_postman_id": "d1e2f3a4-b5c6-7d8e-9f0a-1b2c3d4e5f6a",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Step 1 - Authenticate (Get OAuth Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is valid JSON', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('object');",
              "});",
              "",
              "pm.test('Authentication successful - token received', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('data');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"client_id\": \"{{CAPI_DSAR_Client_Id}}\", \"client_secret\": \"{{CAPI_DSAR_Client_Secret}}\", \"scope\": \"{{CAPI_DSAR_Scope}}\"}"
        },
        "url": {
          "raw": "https://postman-echo.com/post",
          "protocol": "https",
          "host": ["postman-echo", "com"],
          "path": ["post"]
        }
      }
    },
    {
      "name": "Step 2 - Delete User (Valid Request - 200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contains request URL', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.url).to.include('/delete');",
              "});",
              "",
              "pm.test('Delete request processed successfully', function () {",
              "    pm.response.to.be.ok;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer demo-token-12345" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "https://postman-echo.com/delete?userId=test-user-001",
          "protocol": "https",
          "host": ["postman-echo", "com"],
          "path": ["delete"],
          "query": [
            { "key": "userId", "value": "test-user-001" }
          ]
        }
      }
    },
    {
      "name": "Step 3 - Verify User Deleted (GET returns empty)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is valid JSON', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('object');",
              "});",
              "",
              "pm.test('Verification request completed', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.url).to.include('/get');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer demo-token-12345" }
        ],
        "url": {
          "raw": "https://postman-echo.com/get?userId=test-user-001&action=verify-deleted",
          "protocol": "https",
          "host": ["postman-echo", "com"],
          "path": ["get"],
          "query": [
            { "key": "userId", "value": "test-user-001" },
            { "key": "action", "value": "verify-deleted" }
          ]
        }
      }
    },
    {
      "name": "Step 4 - Audit Log Entry Created",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Audit log payload sent correctly', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('action');",
              "    pm.expect(jsonData.data.action).to.eql('USER_DELETE');",
              "});",
              "",
              "pm.test('Audit log contains userId', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('userId');",
              "    pm.expect(jsonData.data.userId).to.eql('test-user-001');",
              "});",
              "",
              "pm.test('Response time is acceptable', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer demo-token-12345" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"action\": \"USER_DELETE\", \"userId\": \"test-user-001\", \"timestamp\": \"2026-02-19T10:00:00Z\", \"performedBy\": \"system\"}"
        },
        "url": {
          "raw": "https://postman-echo.com/post",
          "protocol": "https",
          "host": ["postman-echo", "com"],
          "path": ["post"]
        }
      }
    }
  ]
}
