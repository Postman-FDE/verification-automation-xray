# Jira API credentials
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_BASE_URL=https://your-instance.atlassian.net

# Xray Cloud API credentials
XRAY_CLIENT_ID=your_xray_client_id
XRAY_CLIENT_SECRET=your_xray_client_secret

# Optional: Assignee for created Test Executions (Jira account ID)
JIRA_ASSIGNEE_ACCOUNT_ID=

# Optional: Status transitions after execution (defaults shown)
TRANSITION_ON_PASS=Start Approvals
TRANSITION_ON_FAIL=Done
