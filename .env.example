# ──────────────────────────────────────────────────────────────
# REQUIRED — Jira REST API credentials
# Used for: reading test plans/protocols, updating fields,
#           attaching evidence, transitioning statuses
# Get your API token: https://id.atlassian.com/manage-profile/security/api-tokens
# ──────────────────────────────────────────────────────────────
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_BASE_URL=https://your-instance.atlassian.net

# ──────────────────────────────────────────────────────────────
# REQUIRED — Xray Cloud API credentials
# Used for: creating test executions, linking to test plans/protocols
# Get these from: Xray > Settings > API Keys (in your Jira instance)
# ──────────────────────────────────────────────────────────────
XRAY_CLIENT_ID=your_xray_client_id
XRAY_CLIENT_SECRET=your_xray_client_secret

# ──────────────────────────────────────────────────────────────
# OPTIONAL — Customization
# ──────────────────────────────────────────────────────────────

# Assignee for created Test Executions (Jira account ID)
# If not set, inherits from the Test Plan's assignee automatically.
# Can also be overridden per-run with the --assignee CLI flag.
JIRA_ASSIGNEE_ACCOUNT_ID=

# Sprint custom field ID — varies by Jira instance (defaults to customfield_10006)
JIRA_SPRINT_FIELD=customfield_10006

# Status to transition the Test Execution to after a run.
# "Start Approvals" routes passing executions into the Veera approval queue.
# "Done" is the typical target for failures (manual review needed).
TRANSITION_ON_PASS=Start Approvals
TRANSITION_ON_FAIL=Done

# Set to "false" to enforce SSL certificate validation in Newman.
# Defaults to true (skip SSL checks) for environments with self-signed certs.
NEWMAN_INSECURE=true
